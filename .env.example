# =============================================================================
# Secrets are managed by Doppler (https://dashboard.doppler.com/workplace/projects)
# Run `doppler setup` to link this repo if not already configured.
# Run `doppler run -- <command>` to inject secrets automatically.
#
# If you don't use Doppler, copy this file to .env and fill in the values below.
# =============================================================================

# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# App
PUBLIC_APP_URL=http://localhost:5173
