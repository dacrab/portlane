{
  "name": "portlane",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": { "node": ">=18" },
  "scripts": {
    "dev": "doppler run -- vite dev",
    "build": "doppler run -- vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check && bun run build",
    "db:reset": "supabase db reset",
    "db:seed": "bun supabase/seed.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "bits-ui": "^2.18.1",
    "phosphor-icons-svelte": "^2.1.0",
    "svelte-sonner": "^1.1.1"
  }
}
