{
	"name": "portlane",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "doppler run -- vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"knip": "knip",
		"db:reset": "supabase db reset",
		"db:seed": "bun supabase/seed.ts",
		"test": "vitest run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "6",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.110.1",
		"bits-ui": "^2.18.1",
		"phosphor-icons-svelte": "^2.1.0",
		"stripe": "^22.3.1",
		"svelte-sonner": "^1.1.1"
	}
}
